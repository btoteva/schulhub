{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/messages/threads", "destination": "/api/messaging?route=threads" },
    { "source": "/api/messages/contacts", "destination": "/api/messaging?route=contacts" },
    { "source": "/api/messages/read", "destination": "/api/messaging?route=read" },
    { "source": "/api/messages/unread-count", "destination": "/api/messaging?route=unread-count" },
    { "source": "/api/messages/spaces/search", "destination": "/api/messaging?route=spaces-search" },
    { "source": "/api/messages/spaces/create", "destination": "/api/messaging?route=spaces-create" },
    { "source": "/api/messages/spaces/detail", "destination": "/api/messaging?route=space-detail" },
    { "source": "/api/messages/spaces/messages", "destination": "/api/messaging?route=space-messages" },
    { "source": "/api/messages/spaces/send", "destination": "/api/messaging?route=space-send" },
    { "source": "/api/messages/spaces/read", "destination": "/api/messaging?route=space-read" },
    { "source": "/api/messages", "destination": "/api/messaging" },
    { "source": "/api/push/public-key", "destination": "/api/messaging?route=push-public-key" },
    { "source": "/api/push/subscribe", "destination": "/api/messaging?route=push-subscribe" },
    { "source": "/api/me/weekly-program", "destination": "/api/me?resource=weekly-program" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
